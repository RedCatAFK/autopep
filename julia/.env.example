# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Better Auth
# Secret used by Better Auth
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Drizzle
DATABASE_URL="postgresql://postgres:password@localhost:5432/autopep3"

# Julia worker
JULIA_WORKER_START_URL=""
JULIA_WORKER_WEBHOOK_SECRET=""
JULIA_WORKER_DRY_RUN="1"
JULIA_WORKER_ALLOW_LIVE_RUNS="0"

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="julia"
R2_ENDPOINT_URL=""
R2_REGION="auto"
R2_PUBLIC_BASE_URL=""

# OpenAI
OPENAI_API_KEY=""
OPENAI_DEFAULT_MODEL="gpt-5.5"

# Autopep2 local runtime
AUTOPEP2_SESSION_ID=""
AUTOPEP2_MAX_TOOL_TIMEOUT=""
AUTOPEP2_TOOL_OUTPUT_CHARS=""
AUTOPEP2_MAX_AGENT_TURNS=""

# Julia worker tunables (mirror autopep2's AUTOPEP2_* knobs)
JULIA_MAX_TOOL_TIMEOUT=""
JULIA_TOOL_OUTPUT_CHARS=""
JULIA_MAX_AGENT_TURNS=""

# Optional NCBI settings for PMC literature search
NCBI_API_KEY=""
NCBI_TOOL_EMAIL=""

# Modal inference endpoints
MODAL_CHAI_URL=""
MODAL_CHAI_API_KEY=""
MODAL_PROTEINA_URL=""
MODAL_PROTEINA_API_KEY=""
MODAL_PROTEIN_INTERACTION_SCORING_URL=""
MODAL_PROTEIN_INTERACTION_SCORING_API_KEY=""
MODAL_QUALITY_SCORERS_URL=""
MODAL_QUALITY_SCORERS_API_KEY=""

# DeepSeek provider for the Julia worker. Defaults to OpenRouter; set to
# "fireworks" to route the agent through Fireworks instead. Falls back to
# OPENAI_DEFAULT_MODEL when the chosen provider's API key is missing.
JULIA_DEEPSEEK_PROVIDER="openrouter"

# Fireworks (used when JULIA_DEEPSEEK_PROVIDER="fireworks")
FIREWORKS_API_KEY=""
FIREWORKS_BASE_URL=""
FIREWORKS_DEEPSEEK_MODEL="accounts/fireworks/models/deepseek-v4-pro"
FIREWORKS_REASONING_EFFORT=""

# OpenRouter (default DeepSeek provider for the Julia worker)
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_DEEPSEEK_MODEL="deepseek/deepseek-v4-pro"
OPENROUTER_REASONING_EFFORT="high"
OPENROUTER_APP_TITLE="julia"
OPENROUTER_HTTP_REFERER=""
# Optional comma-separated OpenRouter routing controls.
# OPENROUTER_PROVIDER_IGNORE defaults to "SiliconFlow" because SiliconFlow's
# DeepSeek thinking endpoint rejects multi-turn tool calls when reasoning_content
# is not echoed back, which the OpenAI Agents SDK does not do. Set this to
# an empty-but-explicit value (e.g. " ") only if you have a workaround.
OPENROUTER_PROVIDER_ORDER=""
OPENROUTER_PROVIDER_ONLY=""
OPENROUTER_PROVIDER_IGNORE=""
OPENROUTER_ALLOW_FALLBACKS=""
OPENROUTER_REQUIRE_PARAMETERS="1"
