# OpenAI
OPENAI_API_KEY=""
OPENAI_DEFAULT_MODEL="gpt-5.5"

# Autopep2 local runtime
AUTOPEP2_SESSION_ID="default"
AUTOPEP2_MAX_TOOL_TIMEOUT="120"
AUTOPEP2_TOOL_OUTPUT_CHARS="6000"
AUTOPEP2_MAX_AGENT_TURNS="0"

# Optional NCBI settings for PMC literature search
NCBI_API_KEY=""
NCBI_TOOL_EMAIL=""

# Modal inference endpoints
MODAL_CHAI_URL="https://autopep--chai-1-inference-fastapi-app.modal.run"
MODAL_CHAI_API_KEY=""
MODAL_PROTEINA_URL="https://autopep--proteina-complexa-fastapi-app.modal.run"
MODAL_PROTEINA_API_KEY=""
MODAL_PROTEIN_INTERACTION_SCORING_URL="https://autopep--protein-interaction-scoring-proteinscoringservice-api.modal.run"
MODAL_PROTEIN_INTERACTION_SCORING_API_KEY=""
MODAL_QUALITY_SCORERS_URL="https://autopep--quality-scorers-inference-fastapi-app.modal.run"
MODAL_QUALITY_SCORERS_API_KEY=""

FIREWORKS_API_KEY=""
FIREWORKS_BASE_URL="https://api.fireworks.ai/inference/v1"
FIREWORKS_DEEPSEEK_MODEL="accounts/fireworks/models/deepseek-v4-pro"
FIREWORKS_REASONING_EFFORT="high"

# Temporary DeepSeek provider override
# Fireworks remains available with AUTOPEP2_DEEPSEEK_PROVIDER="fireworks".
AUTOPEP2_DEEPSEEK_PROVIDER="openrouter"
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_DEEPSEEK_MODEL="deepseek/deepseek-v4-pro"
OPENROUTER_REASONING_EFFORT="high"
OPENROUTER_APP_TITLE="autopep2"
# Optional comma-separated OpenRouter routing controls.
OPENROUTER_PROVIDER_ORDER=""
OPENROUTER_PROVIDER_ONLY=""
OPENROUTER_PROVIDER_IGNORE=""
OPENROUTER_ALLOW_FALLBACKS=""
OPENROUTER_REQUIRE_PARAMETERS="1"
