		"check:write": "biome check --write .",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"dev": "next dev",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"modal:deploy": "modal deploy modal/autopep_worker.py",
