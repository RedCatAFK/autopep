# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Better Auth
# Secret used by Better Auth
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Drizzle
DATABASE_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=require"

# Agent worker
# direct = built-in RCSB/PubMed/R2 retrieval worker
# codex = run AUTOPEP_CODEX_COMMAND and let that harness populate DB/artifacts
AUTOPEP_AGENT_MODE="direct"
AUTOPEP_CODEX_COMMAND=""
AUTOPEP_CODEX_MODEL="gpt-5.5"
AUTOPEP_WORKER_ID=""

# Integration smoke runs
# Set AUTOPEP_ALLOW_SMOKE_RUNS=1 only in controlled smoke environments.
AUTOPEP_ALLOW_SMOKE_RUNS="0"
AUTOPEP_SMOKE_OWNER_ID=""
AUTOPEP_SMOKE_WORKSPACE_ID=""
AUTOPEP_SMOKE_THREAD_ID=""

# Run execution backend
# local = leave runs queued for `bun run worker:cif`
# modal = call AUTOPEP_MODAL_START_URL after creating each run
AUTOPEP_RUNNER_BACKEND="local"
AUTOPEP_MODAL_START_URL=""
AUTOPEP_MODAL_WEBHOOK_SECRET=""

# Cloudflare R2 artifact storage
# Required in production. Used for CIF/mmCIF artifact upload and signed viewer URLs.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
# Optional. If set, the app returns public artifact URLs instead of signing R2 reads.
R2_PUBLIC_BASE_URL=""

# Codex / OpenAI harness
# Not used by the built-in direct worker. Set when AUTOPEP_AGENT_MODE="codex" and
# your AUTOPEP_CODEX_COMMAND or child tools call OpenAI APIs.
OPENAI_API_KEY=""

# Default model name persisted on agent runs (overrides the column default).
OPENAI_DEFAULT_MODEL="gpt-5.5"

# Modal sandbox
# Modal deploy/auth credentials for `modal deploy modal/autopep_worker.py`.
# Runtime app secrets above still need to be configured in Modal as a secret.
# The Modal sandbox launcher defaults AUTOPEP_AGENT_MODE to "codex"; set "direct"
# in the Modal runtime secret only when doing deterministic retrieval smoke tests.
MODAL_TOKEN_ID=""
MODAL_TOKEN_SECRET=""

# Modal inference endpoints
# Server-side only. Do not expose these keys in browser code.
MODAL_CHAI_URL="https://autopep--chai-1-inference-fastapi-app.modal.run"
MODAL_CHAI_API_KEY=""
MODAL_PROTEINA_URL="https://autopep--proteina-complexa-fastapi-app.modal.run"
MODAL_PROTEINA_API_KEY=""
MODAL_PROTEIN_INTERACTION_SCORING_URL="https://autopep--protein-interaction-scoring-proteinscoringservice-api.modal.run"
MODAL_PROTEIN_INTERACTION_SCORING_API_KEY=""
